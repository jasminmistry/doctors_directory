NEXT_PUBLIC_BASE_URL=http://localhost:3000

DATABASE_URL="mysql://USER:PASSWORD@HOST:PORT/DATABASE"

# ── Consentz Auth ─────────────────────────────────────────────────────────────
CONSENTZ_AUTH_API_URL=https://auth.consentz.com
CONSENTZ_APPLICATION_ID=admin
# Set to 0 in local dev if Consentz uses a self-signed / internal CA cert.
# Never set this in production.
# NODE_TLS_REJECT_UNAUTHORIZED=0

# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: shared secret for /admin/tracking and GET /api/admin/tracking
# TRACKING_DASHBOARD_TOKEN=your-long-random-string

# Example local DATABASE_URL:
# DATABASE_URL="mysql://root:root@127.0.0.1:8889/directory"

# ── Email (claim verification) ────────────────────────────────────────────────
# Local dev: Mailpit SMTP (default port 1025, no auth)
SMTP_HOST=localhost
SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
EMAIL_FROM="Consentz Directory <noreply@consentz.com>"

# Production: Resend SMTP relay
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASS=re_YOUR_RESEND_API_KEY

# ── Consentz Core (online booking) ───────────────────────────────────────────
# Core booking API uses the same base URL and application ID as auth.
# No extra env vars needed — CONSENTZ_AUTH_API_URL + CONSENTZ_APPLICATION_ID cover it.
# The logged-in admin/portal session token is forwarded as X-SESSION-TOKEN.

# ── Stripe ────────────────────────────────────────────────────────────────────
# Pricing is defined in code — no Stripe Products or Price IDs needed.
# Subscription plan: £99/month recurring (Checkout Session, subscription mode)
# PPL plan: SetupIntent at claim → £15 per-lead charged via off_session PaymentIntent on unlock
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
